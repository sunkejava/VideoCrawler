{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=vodcrawler.db"
  },
  "Cache": {
    "Path": "./cache",
    "DefaultExpirationDays": 30,
    "MaxSizeGB": 10
  },
  "Crawler": {
    "MaxPages": 10,
    "VideosPerPage": 40,
    "RequestDelayMs": 1000,
    "TimeoutSeconds": 30,
    "MaxRetries": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "VideoCrawler": "Debug"
    }
  },
  "AllowedHosts": "*"
}
